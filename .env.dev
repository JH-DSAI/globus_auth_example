# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# Globus Application credentials
# Register a Confidential App at https://app.globus.org/settings/developers
# and add http://127.0.0.1:8000/callback as an allowed redirect URL.
GLOBUS_CLIENT_ID=<client-id>
GLOBUS_CLIENT_SECRET=<client-secret>

# The OAuth 2.0 redirect URI registered with your Globus app.
# Must exactly match what is registered in the Globus developer console.
REDIRECT_URI=http://127.0.0.1:8000/callback

# Secret key used to sign the session cookie.
# Generate a strong random value: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=change-me-to-a-long-random-secret

# secure session cookie settings ===============================================
# The number of seconds that the session cookie is valid for.
SESSION_COOKIE_MAX_AGE_SECONDS=3600
# Set to true to enable secure cookies (requires HTTPS), use false for dev
SESSION_COOKIE_SECURE=false
# Set to true to enable httpOnly cookies (prevents XSS attacks)
# kees the cookie from being accessed by javascript
SESSION_COOKIE_HTTPONLY=true
# needs to be set to lax to support keeping the cookie preserved through redirects
SESSION_COOKIE_SAMESITE=lax
